# Server
PORT=3000

# MongoDB (optional; server will run without it)
# Local example:
# MONGODB_URI=mongodb://127.0.0.1:27017/traverplanner
# Atlas example (DO NOT put real usernames/passwords in this file):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority
MONGODB_URI=

# Optional: Mongo server selection timeout (ms)
# MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
